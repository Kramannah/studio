rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the user is an admin.
     * Verified by UID list or official admin email.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"] ||
        (request.auth.token.email != null && request.auth.token.email == "mbustamante@hovidinc.com")
      );
    }

    /** 
     * Checks if the user is a manager.
     * UIDs sourced from territory management configuration.
     */
    function isManager() {
      return isSignedIn() && request.auth.uid in [
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1",
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2",
        "r19lVIqk4xTtzxvbs4W0kprHSvD2", "lDprIWp1acWrMElyzk2uTjQ4q4m1"
      ];
    }

    /** Verifies ownership of a document via a userId field. */
    function isOwner(data) {
      return isSignedIn() && request.auth.uid == data.userId;
    }

    // --- Collection Rules ---

    // Allow Admins and Managers full read access to all reporting collections
    // Users are restricted to their own data via filters in the application

    match /coverageEntries/{id} {
      allow read, update, delete: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
    }

    match /doctors/{id} {
      allow read, update, delete: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
    }

    match /plans/{id} {
      allow read, update, delete: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
    }

    match /nonCallDays/{id} {
      allow read, update, delete: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
    }

    match /timeLogs/{id} {
      allow read, update, delete: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
    }

    match /planningRequests/{id} {
      allow read, update, delete: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isSignedIn() && isOwner(request.resource.data);
    }

    // Inventory and Allocation rules
    match /q4Allocation/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /marketingSamples/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}