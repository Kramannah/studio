
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/userProfiles/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let adminUids = ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"];
      let adminEmails = ["mbustamante@hovidinc.com", "admin@hovidinc.com"];
      let email = request.auth.token.get('email', '').lower();
      let profile = getUserData();
      return isSignedIn() && (
        request.auth.uid in adminUids ||
        email in adminEmails ||
        (profile != null && profile.role == "Admin")
      );
    }

    function isManager() {
      let managerUids = [
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1",
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2",
        "r19lVIqk4xTtzxvbs4W0kprHSvD2"
      ];
      let profile = getUserData();
      return isSignedIn() && (
        request.auth.uid in managerUids || 
        (profile != null && profile.role == "Manager") ||
        isAdmin()
      );
    }

    function isStaff() {
      let profile = getUserData();
      return isSignedIn() && profile != null && (profile.role == "Marketing" || profile.role == "HR");
    }

    function isOwner(userId) {
      return isSignedIn() && userId == request.auth.uid;
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      // Prioritize isOwner check to avoid expensive role checks for PMRs
      allow read, list: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || isManager() || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource != null && resource.data.userId == request.auth.uid)) || isAdmin();
    }

    match /doctors/{id} {
      allow read, list: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || isManager() || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource != null && resource.data.userId == request.auth.uid)) || isAdmin();
    }

    match /plans/{id} {
      allow read, list: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || isManager() || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource != null && resource.data.userId == request.auth.uid)) || isAdmin();
    }

    match /nonCallDays/{id} {
      allow read, list: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || isManager() || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource != null && resource.data.userId == request.auth.uid)) || isAdmin();
    }

    match /timeLogs/{id} {
      allow read, list: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || isManager() || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource != null && resource.data.userId == request.auth.uid)) || isAdmin();
    }

    match /planningRequests/{id} {
      allow read, list: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || isManager() || isStaff();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource != null && resource.data.userId == request.auth.uid)) || isAdmin();
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }
    
    match /userProfiles/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isManager() || (isSignedIn() && request.auth.uid == id);
    }
  }
}
