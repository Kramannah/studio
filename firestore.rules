
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Optimized Profile Lookup (Firestore caches this for the duration of the request)
    function getProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    // Role-based Access Logic
    function hasInternalAccess() {
      if (!isSignedIn()) return false;
      let profile = getProfile();
      let role = profile.get('role', 'PMR');
      return role == "Admin" || role == "Manager" || role == "Marketing" || role == "HR";
    }

    function isOwner(userId) {
      return isSignedIn() && userId == request.auth.uid;
    }

    function isAdminFallback() {
      let adminUids = ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"];
      let adminEmails = ["mbustamante@hovidinc.com", "admin@hovidinc.com"];
      return request.auth.uid in adminUids || request.auth.token.get('email', '').lower() in adminEmails;
    }

    // Universal Read/Write Check
    function canAccessData(userId) {
      return isOwner(userId) || hasInternalAccess() || isAdminFallback();
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if hasInternalAccess() || isAdminFallback();
    }
    
    match /userProfiles/{id} {
      allow read, list: if isSignedIn();
      allow write: if hasInternalAccess() || isAdminFallback() || (isSignedIn() && request.auth.uid == id);
    }
  }
}
