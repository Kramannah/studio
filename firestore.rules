
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. MARKETING SAMPLES - ABSOLUTE PRIORITY OVERRIDE
    match /marketingSamples/{document=**} {
        allow read: if request.auth != null;
        // Direct email and UID check for mbustamante@hovidinc.com to bypass any role logic failures
        allow create, update, delete: if request.auth != null && (
          request.auth.token.email.lower() == 'mbustamante@hovidinc.com' || 
          request.auth.uid == 'SgOR5cjCC6dZ0oABv4nXdntu6pI3'
        );
    }

    // Centralized check for Admin or Manager status.
    function isAuthorized() {
      if (request.auth == null) return false;
      
      let email = request.auth.token.email;
      let userEmail = (email == null) ? "" : email.lower();
      let uid = request.auth.uid;

      // Direct whitelist for primary admin and hovid domain
      let isAdmin = userEmail == 'mbustamante@hovidinc.com' || userEmail.endsWith('@hovidinc.com');

      // List of authorized UIDs (Managers).
      let isWhitelistedUid = uid in [
        "SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2",
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1", 
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2", 
        "r19lVIqk4xTtzxvbs4W0kprHSvD2", "lDprIWp1acWrMElyzk2uTjQ4q4m1"
      ];

      return isAdmin || isWhitelistedUid;
    }

    // 2. Doctor Masterlist
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAuthorized());
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAuthorized());
    }

    // 3. Coverage Reports
    match /coverageEntries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAuthorized());
    }
    
    // 4. Call Plans
    match /plans/{planId} {
      allow read, create: if request.auth != null;
      allow delete, update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // 5. Non-Call Days & Planning Requests
    match /nonCallDays/{dayId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isAuthorized();
    }
    
    match /planningRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isAuthorized();
    }

    // 6. Time logs
    match /timeLogs/{logId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
