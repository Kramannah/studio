
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-based Access Logic - Optimized for speed and safety
    // Uses a cheap token check for admins first to avoid unnecessary document reads
    function isAdminFallback() {
      let adminEmails = ["mbustamante@hovidinc.com", "admin@hovidinc.com", "wbmaralit@hovidinc.com"];
      return isSignedIn() && (request.auth.token.get('email', '').lower() in adminEmails);
    }

    // High-performance Access Helper
    // Priority 1: Ownership (Cheapest & Fastest, avoids timeouts for large list queries)
    // Priority 2: Admin/Internal Role checks (Executed only if ownership check fails)
    function canAccessData(docUserId) {
      if (!isSignedIn()) return false;
      
      // CHEAP SHORT-CIRCUIT: If the user owns the data, grant access immediately.
      // This prevents the Rules engine from running expensive 'get()' calls on every document in a list.
      if (docUserId == request.auth.uid) return true;
      
      // SECONDARY CHEAP CHECK: Admin email check in token.
      if (isAdminFallback()) return true;
      
      // TERTIARY: Internal Role check (Resilient check for profile existence)
      let profilePath = /databases/$(database)/documents/userProfiles/$(request.auth.uid);
      return exists(profilePath) && (
        get(profilePath).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"]
      );
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdminFallback() || (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"]);
    }
    
    match /userProfiles/{id} {
      // Allow users to see their own profile without recursive checks
      allow read: if isSignedIn() && (request.auth.uid == id || isAdminFallback());
      allow write: if isSignedIn() && (request.auth.uid == id || isAdminFallback());
      allow list: if isSignedIn() && (isAdminFallback() || (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"]));
    }
  }
}
