rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isManager() {
      // NOTE: This is a temporary solution. In a production app, manage roles
      // via custom claims or a roles collection in Firestore.
      return request.auth.uid in [
        "UmyUP0VwccRKLfrej67idFukFz42", // Azarel Daquioag
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", // Erica Gonzales
        "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1"  // Eula Candawan
      ];
    }

    match /coverageEntries/{entryId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    match /doctors/{doctorId} {
      allow read, create, update, delete: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }
    
    match /plans/{planId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    match /nonCallDays/{dayId} {
        allow read, create: if isOwner(request.resource.data.userId);
        allow update: if isManager();
    }
    
    match /timeLogs/{logId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId);
    }
    
    match /marketingSamples/{sampleId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false; // Managed by admin backend process
    }
    
    match /planningRequests/{requestId} {
        allow read, create: if isOwner(request.resource.data.userId);
        allow update: if isManager();
    }
  }
}
