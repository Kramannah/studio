rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the user is an admin.
     * Uses both hardcoded UIDs and email patterns.
     */
    function isAdmin() {
      let adminUids = ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"];
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && (
        request.auth.uid in adminUids ||
        email == "mbustamante@hovidinc.com" ||
        email == "admin@hovidinc.com"
      );
    }

    /** 
     * Checks if the user is a manager.
     */
    function isManager() {
      let managerUids = [
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1",
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2",
        "r19lVIqk4xTtzxvbs4W0kprHSvD2", "lDprIWp1acWrMElyzk2uTjQ4q4m1"
      ];
      return isSignedIn() && (request.auth.uid in managerUids);
    }

    /**
     * Common ownership check.
     */
    function isOwner(userId) {
      return isSignedIn() && userId == request.auth.uid;
    }

    // --- Specific Collection Rules ---

    // Coverage Entries
    match /coverageEntries/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Doctors Masterlist
    match /doctors/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Call Plans
    match /plans/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Non-Call Days / Leave
    match /nonCallDays/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Attendance / Time Logs
    match /timeLogs/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Planning Permission Requests
    match /planningRequests/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Inventory Allocations
    match /q4Allocation/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Marketing Samples
    match /marketingSamples/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // User Profiles
    match /userProfiles/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || (isSignedIn() && request.auth.uid == id);
    }
  }
}