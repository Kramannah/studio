
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the user is an admin.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"] ||
        request.auth.token.email.lower() == "mbustamante@hovidinc.com"
      );
    }

    /** 
     * Checks if the user is a manager.
     */
    function isManager() {
      return isSignedIn() && request.auth.uid in [
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1",
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2",
        "r19lVIqk4xTtzxvbs4W0kprHSvD2", "lDprIWp1acWrMElyzk2uTjQ4q4m1"
      ];
    }

    /**
     * Common ownership check.
     */
    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      // TEAM-WIDE POOL: All users can read entries to calculate global sample usage.
      allow read: if isSignedIn(); 
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    match /doctors/{id} {
      // Explicit access for managers to read territory doctor lists
      allow read: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    match /plans/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    match /nonCallDays/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    match /timeLogs/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    match /planningRequests/{id} {
      allow read: if isAdmin() || isManager() || isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    match /q4Allocation/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /marketingSamples/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
