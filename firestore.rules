rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the user is an admin or a manager.
     * UIDs sourced from src/lib/admins.ts
     */
    function isAdminOrManager() {
      return isSignedIn() && request.auth.uid in [
        "SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2", // Admins
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1",
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2",
        "r19lVIqk4xTtzxvbs4W0kprHSvD2", "lDprIWp1acWrMElyzk2uTjQ4q4m1"  // Managers
      ];
    }

    /** Verifies ownership of a document via a userId field. */
    function isOwner(data) {
      return isSignedIn() && request.auth.uid == data.userId;
    }

    // --- Collection Rules ---

    // Generic rule for collections where documents have a 'userId' field
    match /{collectionName}/{docId} {
      allow read: if isSignedIn() && (
        collectionName in ['doctors', 'coverageEntries', 'nonCallDays', 'plans', 'planningRequests', 'timeLogs'] && 
        (isOwner(resource.data) || isAdminOrManager())
      );
      
      allow create: if isSignedIn() && (
        collectionName in ['doctors', 'coverageEntries', 'nonCallDays', 'plans', 'planningRequests', 'timeLogs'] && 
        isOwner(request.resource.data)
      );

      allow update, delete: if isSignedIn() && (
        collectionName in ['doctors', 'coverageEntries', 'nonCallDays', 'plans', 'planningRequests', 'timeLogs'] && 
        (isOwner(resource.data) || isAdminOrManager())
      );
    }

    // Inventory and Allocation rules
    match /q4Allocation/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    match /marketingSamples/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }

    // Static lookup data
    match /clinics/{clinicId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrManager();
    }
  }
}