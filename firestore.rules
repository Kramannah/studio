
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-based Access Logic - ULTRA-OPTIMIZED FOR VETERAN ACCOUNTS
    // Short-circuits instantly if the user is the owner to prevent rule engine timeouts.
    function canAccessData(docUserId) {
      if (!isSignedIn()) return false;
      
      // PRIORITY 1: Ownership (Instant Short-circuit)
      // This is the fastest path and prevents crashes for users with 3,000+ records.
      if (docUserId == request.auth.uid) return true;
      
      // PRIORITY 2: Admin/Internal Role checks (Manager oversight)
      // Only executed if the user is NOT the owner.
      let adminEmails = ["mbustamante@hovidinc.com", "admin@hovidinc.com", "wbmaralit@hovidinc.com"];
      if (request.auth.token.get('email', '').lower() in adminEmails) return true;
      
      let profilePath = /databases/$(database)/documents/userProfiles/$(request.auth.uid);
      // Use exists check to prevent evaluation crashes on missing veteran profiles
      return exists(profilePath) && (
        get(profilePath).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"]
      );
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.token.get('email', '').lower() in ["mbustamante@hovidinc.com", "admin@hovidinc.com"] ||
        (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"])
      );
    }
    
    match /userProfiles/{id} {
      allow read: if isSignedIn() && (request.auth.uid == id || canAccessData('MANAGERIAL_OVERRIDE'));
      allow write: if isSignedIn() && (request.auth.uid == id || canAccessData('MANAGERIAL_OVERRIDE'));
      allow list: if isSignedIn() && (canAccessData('MANAGERIAL_OVERRIDE'));
    }
  }
}
