
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Admin check: either by a specific email domain or by being in the list of hardcoded admin UIDs.
      return request.auth.token.email.endsWith('@hovidinc.com') || request.auth.uid in ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"];
    }

    // Allow users to read, create, update, and delete their own doctor masterlist.
    // Admins can also create, update, and delete for other users.
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Allow users to manage their own coverage entries.
    match /coverageEntries/{entryId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Allow users to manage their own call plans.
    match /plans/{planId} {
      allow read, create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // A user can create/read their own non-call days. Only an admin can update (approve/reject).
    match /nonCallDays/{dayId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isAdmin();
    }
    
    // A user can create/read their own planning requests. Only an admin can update (approve/reject).
    match /planningRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isAdmin();
    }
    
    // Marketing samples are read-only for users, but writable for admins.
    match /marketingSamples/{sampleId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && isAdmin(); // Use isAdmin function
    }

    // Time logs can be created and updated by the user who owns them.
    match /timeLogs/{logId} {
        allow read, create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
