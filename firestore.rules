rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Security rules for admins collection
    match /admins/{adminId} {
      allow read;
    }

    match /doctors/{docId} {
      allow read, create, update, delete: if isOwner(request.resource.data.userId);
    }
    
    match /coverageEntries/{docId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read, update, delete: if isOwner(resource.data.userId);
    }

    match /plans/{planId} {
      allow read, create, delete: if isOwner(request.auth.uid);
    }

    match /nonCallDays/{dayId} {
      allow read, create: if isOwner(request.auth.uid);
      allow update: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /planningRequests/{reqId} {
        allow read, create: if isOwner(request.auth.uid);
        allow update: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /marketingSamples/{sampleId} {
        allow read: if request.auth != null;
        allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /timeLogs/{logId} {
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId);
      allow read: if isOwner(resource.data.userId);
    }
  }
}
