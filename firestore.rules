rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /coverageEntries/{entryId} {
      allow read, write: if isOwner(resource.data.userId);
    }
    
    match /doctors/{doctorId} {
        allow read, write: if isOwner(resource.data.userId);
    }

    match /plans/{planId} {
        allow read, write: if isOwner(resource.data.userId);
    }
    
    match /nonCallDays/{dayId} {
        allow read, write: if isOwner(resource.data.userId);
        allow update: if request.auth.uid in get(/databases/$(database)/documents/managers/--permissions--).data.approvers;
    }
    
    match /timeLogs/{logId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    match /marketingSamples/{sampleId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid in get(/databases/$(database)/documents/managers/--permissions--).data.admins;
    }

    match /planningRequests/{requestId} {
        allow read, write: if isOwner(resource.data.userId);
        allow update: if request.auth.uid in get(/databases/$(database)/documents/managers/--permissions--).data.approvers;
    }
  }
}
