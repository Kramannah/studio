rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for role checks
    function isAdmin() {
      // The list of Admin UIDs.
      let adminUIDs = ["SgOR5cjCC6dZ0oABv4nXdntu6pI3"];
      return request.auth.uid in adminUIDs;
    }

    function isManager() {
        // The list of Manager UIDs
        let managerUIDs = ["UmyUP0VwccRKLfrej67idFukFz42", "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1"];
        return request.auth.uid in managerUIDs;
    }

    // Match all collections
    match /{collection}/{docId} {
      // Deny all reads and writes by default
      allow read, write: if false;
    }

    // Rules for 'doctors' collection
    match /doctors/{doctorId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Rules for 'coverageEntries' collection
    match /coverageEntries/{entryId} {
      allow read, create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Rules for 'plans' collection
    match /plans/{planId} {
      allow read, create, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Rules for 'nonCallDays' collection
    match /nonCallDays/{dayId} {
      allow read, create: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null && (isAdmin() || isManager());
    }
    
    // Rules for 'timeLogs' collection
    match /timeLogs/{logId} {
        allow read, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Rules for 'marketingSamples' collection
    match /marketingSamples/{sampleId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && isAdmin();
    }
    
    // Rules for 'planningRequests' collection
    match /planningRequests/{requestId} {
        allow read, create: if request.auth != null && resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && (isAdmin() || isManager());
    }
  }
}
