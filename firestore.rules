rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /coverageEntries/{entryId} {
      allow read, create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /doctors/{doctorId} {
      allow read, create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    match /plans/{planId} {
      allow read, create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    match /marketingSamples/{sampleId} {
      allow read: if isSignedIn();
      // Admin-only write rules would be managed via a different mechanism
      // For now, we allow signed-in users to read.
      allow write: if false; 
    }

    match /nonCallDays/{dayId} {
        allow read, create: if isSignedIn() && isOwner(request.resource.data.userId);
        allow update: if isSignedIn() && (isOwner(resource.data.userId) || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true);
    }
    
    match /timeLogs/{logId} {
        allow read, create: if isSignedIn() && isOwner(request.resource.data.userId);
        allow update: if isSignedIn() && isOwner(resource.data.userId);
    }
    
    match /planningRequests/{reqId} {
        allow read, create: if isSignedIn() && isOwner(request.resource.data.userId);
        allow update: if isSignedIn() && (isOwner(resource.data.userId) || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true);
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
    }
  }
}
