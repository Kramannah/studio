
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Centralized check for Admin or Manager status.
    function isAuthorized() {
      // Ensure the user is authenticated.
      if (request.auth == null) {
        return false;
      }

      let userEmail = request.auth.token.email;
      let uid = request.auth.uid;

      // Check if email matches mbustamante@hovidinc.com or the company domain (case-insensitive).
      let isHovidAdmin = userEmail != null && (
        userEmail.matches('(?i)^mbustamante@hovidinc\\.com$') ||
        userEmail.matches('(?i).*@hovidinc\\.com$')
      );

      // List of authorized UIDs (Admins and Managers).
      let isWhitelistedUid = uid in [
        // Admins
        "SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2",
        // Managers (DSMs)
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1", 
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2", 
        "r19lVIqk4xTtzxvbs4W0kprHSvD2", "lDprIWp1acWrMElyzk2uTjQ4q4m1"
      ];

      return isHovidAdmin || isWhitelistedUid;
    }

    // Doctor Masterlist: Users manage their own; Admins/Managers manage all.
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAuthorized());
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAuthorized());
    }

    // Coverage Reports: Users create their own; Admins/Managers manage all.
    match /coverageEntries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAuthorized());
    }
    
    // Call Plans: Users manage their own.
    match /plans/{planId} {
      allow read, create: if request.auth != null;
      allow delete, update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Non-Call Days & Planning Requests: User creates; Admin/Manager approves.
    match /nonCallDays/{dayId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isAuthorized();
    }
    
    match /planningRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isAuthorized();
    }
    
    // Marketing Samples: Allow write access to any authenticated user who can access the feature.
    match /marketingSamples/{sampleId} {
        allow read, write: if request.auth != null;
    }

    // Time logs: Managed by the owner.
    match /timeLogs/{logId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
