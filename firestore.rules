
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let adminUids = ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"];
      let email = request.auth.token.get('email', '').lower();
      return isSignedIn() && (
        request.auth.uid in adminUids ||
        email == "mbustamante@hovidinc.com" ||
        email == "admin@hovidinc.com" ||
        getUserData().role == "Admin"
      );
    }

    function isManager() {
      let managerUids = [
        "e11qs3XD1vW3JWHfEaJI2DXcCEj2", "UmyUP0VwccRKLfrej67idFukFz42", 
        "tb73WEIzndUrPEaD1q4H0VQfQaD3", "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1",
        "x8u4kvWvieZIVc9NdgiWmG01nts2", "MlE49ceLEDbzvKAsisKnW07fGfW2",
        "r19lVIqk4xTtzxvbs4W0kprHSvD2"
      ];
      return isSignedIn() && (
        request.auth.uid in managerUids || 
        getUserData().role == "Manager" ||
        isAdmin()
      );
    }

    function isOwner(userId) {
      return isSignedIn() && userId == request.auth.uid;
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      allow read, list: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if isAdmin() || isManager() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /userProfiles/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isManager() || (isSignedIn() && request.auth.uid == id);
    }
  }
}
