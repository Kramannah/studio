
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-based Access Logic - Optimized for speed and safety
    function hasInternalAccess() {
      if (!isSignedIn()) return false;
      let profilePath = /databases/$(database)/documents/userProfiles/$(request.auth.uid);
      
      // CRITICAL: exists() check prevents rule crashes on missing profile documents
      if (!exists(profilePath)) return false;
      
      let role = get(profilePath).data.get('role', 'PMR');
      return role == "Admin" || role == "Manager" || role == "Marketing" || role == "HR";
    }

    function isAdminFallback() {
      let adminEmails = ["mbustamante@hovidinc.com", "admin@hovidinc.com", "wbmaralit@hovidinc.com"];
      return isSignedIn() && (request.auth.token.get('email', '').lower() in adminEmails);
    }

    // Optimized Read/Write Check - Prioritize ownership to bypass expensive role-checks
    function canAccessData(docUserId) {
      return isSignedIn() && (
        docUserId == request.auth.uid || 
        isAdminFallback() || 
        hasInternalAccess()
      );
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdminFallback() || hasInternalAccess();
    }
    
    match /userProfiles/{id} {
      // Allow users to see their own profile without recursive hasInternalAccess checks
      allow read, write: if isSignedIn() && (request.auth.uid == id || isAdminFallback() || hasInternalAccess());
      allow list: if isSignedIn() && (isAdminFallback() || hasInternalAccess());
    }
  }
}
