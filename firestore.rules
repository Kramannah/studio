
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-based Access Logic - Resilient to missing profile documents
    function hasInternalAccess() {
      if (!isSignedIn()) return false;
      let profilePath = /databases/$(database)/documents/userProfiles/$(request.auth.uid);
      
      // CRITICAL: Check existence before accessing .data to prevent rule crashes
      if (!exists(profilePath)) return false;
      
      let profile = get(profilePath).data;
      let role = profile.get('role', 'PMR');
      return role == "Admin" || role == "Manager" || role == "Marketing" || role == "HR";
    }

    function isAdminFallback() {
      let adminUids = ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"];
      let adminEmails = ["mbustamante@hovidinc.com", "admin@hovidinc.com", "wbmaralit@hovidinc.com"];
      return isSignedIn() && (request.auth.uid in adminUids || request.auth.token.get('email', '').lower() in adminEmails);
    }

    // Optimized Read/Write Check - Prioritize ownership to bypass role-checks for PMRs
    function canAccessData(docUserId) {
      return isSignedIn() && (
        docUserId == request.auth.uid || 
        isAdminFallback() || 
        hasInternalAccess()
      );
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      // Split list and get for maximum performance on large datasets
      allow list: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdminFallback() || hasInternalAccess());
      allow get: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if canAccessData(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if canAccessData(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdminFallback() || hasInternalAccess();
    }
    
    match /userProfiles/{id} {
      // Allow users to see and manage their own profile even if the doc doesn't exist yet
      allow read, list, write: if isSignedIn() && (request.auth.uid == id || isAdminFallback() || hasInternalAccess());
    }
  }
}
