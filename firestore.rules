/**
 * Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a strict User-Ownership model where all application data is nested 
 * under a specific user's path. This ensures "Authorization Independence," meaning the path 
 * itself dictates access without requiring expensive lookups to separate documents. 
 * Administrative access is managed through a dedicated role-based collection.
 *
 * Data Structure:
 * - /users/{userId}: The root document for a user.
 * - /users/{userId}/providers/{providerId}: Provider data owned by the specific user.
 * - /users/{userId}/coverageEvents/{coverageEventId}: Coverage events recorded by the specific user.
 * - /admin_roles/{adminId}: A collection where the presence of a document grants global admin privileges.
 *
 * Key Security Decisions:
 * - Default posture: Access is denied unless explicitly granted.
 * - Path-based Authorization: Users are granted access to their own data trees based on the {userId} in the path.
 * - Admin Override: Users with a document in /admin_roles/ are permitted to perform read operations across all user collections.
 * - Ownership Consistency: During creation, we enforce that the 'id' field in the document matches the ID in the path.
 *
 * Denormalization for Authorization:
 * - While primary access is path-based, critical identifiers like 'id' are validated against 
 *   the path to ensure data integrity within the document matches its storage location.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the document exists and the current user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** 
     * Checks if the current user has administrative privileges.
     * Administrative status is determined by the existence of a document in the admin_roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- Rules ---

    /**
     * @description Rules for the root user document. Users can manage their own profile.
     * @path /users/{userId}
     * @allow (create) Authenticated user where path matches UID.
     * @deny (get) Access to other users' profile documents.
     * @principle Self-creation and ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();

      /**
       * @description Rules for Provider entities. Providers are strictly owned by the parent user.
       * @path /users/{userId}/providers/{providerId}
       * @allow (list) The owner listing their own providers.
       * @deny (update) Changing the provider's unique ID after creation.
       * @principle Authorization Independence via hierarchical paths.
       */
      match /providers/{providerId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.id == providerId;
        allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      /**
       * @description Rules for CoverageEvent entities. Events are private records of a specific user.
       * @path /users/{userId}/coverageEvents/{coverageEventId}
       * @allow (create) Owner creating a record with a matching ID.
       * @deny (create) User attempting to create a record in another user's path.
       * @principle Relational integrity and path-based security.
       */
      match /coverageEvents/{coverageEventId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.id == coverageEventId;
        allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Supports Collection Group queries for administrators (e.g., Q4 Batch 1 Sample view).
     * @path /{path=**}/coverageEvents/{coverageEventId}
     * @allow (list) Global administrators only.
     * @deny (list) Standard users attempting to query all coverage events.
     * @principle Role-based administrative access.
     */
    match /{path=**}/coverageEvents/{coverageEventId} {
      allow list: if isAdmin();
    }

    /**
     * @description Rules for Admin Roles. This collection acts as a whitelist for admin privileges.
     * @path /admin_roles/{adminId}
     * @allow (get) Any signed-in user to verify their own role status.
     * @deny (write) Any client-side modification of administrative roles.
     * @principle Database Access Control (DBAC) via existence checks.
     */
    match /admin_roles/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}