
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth.uid in ["SgOR5cjCC6dZ0oABv4nXdntu6pI3"];
    }
    
    function isManager() {
      // In a real app, this would be a lookup in a 'roles' collection.
      // For this example, we are hardcoding manager UIDs for simplicity.
      return request.auth.uid in [
        "UmyUP0VwccRKLfrej67idFukFz42",
        "tb73WEIzndUrPEaD1q4H0VQfQaD3",
        "I3HkxWKsKZOPdmUT9Hi1G8JUy5t1"
      ];
    }

    match /coverageEntries/{entryId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      // Only allow users to update entries within the same week of submission.
      allow update: if isOwner(resource.data.userId) && request.time.toMillis() < resource.data.submittedAt.toMillis() + (7 * 24 * 60 * 60 * 1000);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /plans/{planId} {
      allow read, create: if request.auth != null && isOwner(request.resource.data.userId);
      allow delete: if request.auth != null && isOwner(resource.data.userId);
    }
    
    match /nonCallDays/{dayId} {
      allow read, create: if request.auth != null && isOwner(request.resource.data.userId);
      allow update: if request.auth != null && (isAdmin() || isManager());
    }

    match /timeLogs/{logId} {
        allow read, create: if request.auth.uid == request.resource.data.userId;
        allow update: if request.auth.uid == resource.data.userId;
    }

    match /marketingSamples/{sampleId} {
        allow read: if request.auth != null;
        allow create, delete: if isAdmin();
    }
    
    match /planningRequests/{requestId} {
        allow read, create: if request.auth.uid == request.resource.data.userId;
        allow update: if request.auth != null && (isAdmin() || isManager());
    }
  }
}
