
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Ultra-Fast Ownership Check (No DB lookups)
    // CRITICAL: Used to prevent Rule Engine complexity timeouts for veteran accounts
    function isOwner(docUserId) {
      return isSignedIn() && docUserId == request.auth.uid;
    }

    // Token-based whitelist check (No DB lookups)
    function isSpecialAuthorizedPMR() {
      let email = request.auth.token.get('email', '').lower();
      return email in ["kgpangan@hovidinc.com", "pjramos@hovidinc.com"];
    }

    // Role-based check (Database lookup - ONLY for managerial oversight)
    function isManagerialAccess(docUserId) {
      if (!isSignedIn()) return false;
      
      // Ownership check short-circuit
      if (docUserId == request.auth.uid) return true;
      
      // Admin whitelist (No DB lookup)
      let authorizedEmails = [
        "mbustamante@hovidinc.com", 
        "admin@hovidinc.com", 
        "wbmaralit@hovidinc.com"
      ];
      if (request.auth.token.get('email', '').lower() in authorizedEmails) return true;
      
      // Profile lookup (Only run if ownership/whitelist fails)
      let profilePath = /databases/$(database)/documents/userProfiles/$(request.auth.uid);
      return exists(profilePath) && (
        get(profilePath).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"]
      );
    }

    // --- Collection Rules ---

    match /coverageEntries/{id} {
      // Rule Priority: Owner > Special Whitelist > DSM/Manager
      allow read, list: if isSignedIn() && (
        isOwner(resource.data.userId) || 
        isSpecialAuthorizedPMR() || 
        isManagerialAccess(resource.data.userId)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isManagerialAccess(resource.data.userId);
    }

    match /doctors/{id} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.userId) || isManagerialAccess(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isManagerialAccess(resource.data.userId);
    }

    match /plans/{id} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.userId) || isManagerialAccess(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isManagerialAccess(resource.data.userId);
    }

    match /nonCallDays/{id} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.userId) || isManagerialAccess(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isManagerialAccess(resource.data.userId);
    }

    match /timeLogs/{id} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.userId) || isManagerialAccess(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isManagerialAccess(resource.data.userId);
    }

    match /planningRequests/{id} {
      allow read, list: if isSignedIn() && (isOwner(resource.data.userId) || isManagerialAccess(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isManagerialAccess(resource.data.userId);
    }

    match /marketingSamples/{id} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.token.get('email', '').lower() in ["mbustamante@hovidinc.com", "admin@hovidinc.com"] ||
        isManagerialAccess('OVERRIDE_FOR_MARKETING')
      );
    }
    
    match /userProfiles/{id} {
      allow read: if isSignedIn() && (request.auth.uid == id || isManagerialAccess('MANAGERIAL_OVERRIDE'));
      allow write: if isSignedIn() && (request.auth.uid == id || isManagerialAccess('MANAGERIAL_OVERRIDE'));
      allow list: if isSignedIn() && (isManagerialAccess('MANAGERIAL_OVERRIDE'));
    }
  }
}
