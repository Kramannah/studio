rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to verify if the user is a system administrator or manager
    // This now dynamically checks the Firestore 'userProfiles' collection
    function isSystemAdmin() {
      let profilePath = /databases/(default)/documents/userProfiles/$(request.auth.uid);
      let email = request.auth.token.get('email', '').lower();
      
      // Explicit Whitelist (Fastest)
      let isWhitelisted = email in ["mbustamante@hovidinc.com", "wbmaralit@hovidinc.com", "admin@hovidinc.com"];
      
      // Database Role Check (Robust)
      // Note: We use get() which allows Storage rules to read Firestore data
      let hasAdminRole = firestore.exists(profilePath) && 
                         firestore.get(profilePath).data.get('role', 'PMR') in ["Admin", "Manager", "Marketing", "HR"];
      
      return isSignedIn() && (isWhitelisted || hasAdminRole);
    }

    // Coverage folder rules
    match /coverage/{userId}/{allPaths=**} {
      // Anyone logged in can read (for oversight/history)
      allow read: if isSignedIn();
      
      // Allow write if:
      // 1. The user is the owner of the folder
      // 2. The user is an authorized System Admin/Manager (Crucial for Migration)
      allow write: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
