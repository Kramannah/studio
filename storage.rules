rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /coverage/{userId}/{allPaths=**} {
      // standard read/write isolated to the folder owner
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
