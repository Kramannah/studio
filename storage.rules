rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Logic for Coverage Proofs (Photos and Signatures)
    match /coverage/{userId}/{allPaths=**} {
      // Allow any authenticated user to read (for Admin oversight and PMR history)
      allow read: if request.auth != null;
      
      // Allow write if:
      // 1. The user owns the folder (Standard PMR upload)
      // 2. The user is an authorized Admin via Email (Master Key for Migration)
      // 3. The user is a hardcoded Admin via UID
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.get('email', '').lower() in [
          "mbustamante@hovidinc.com", 
          "wbmaralit@hovidinc.com", 
          "admin@hovidinc.com"
        ] ||
        request.auth.uid in ["SgOR5cjCC6dZ0oABv4nXdntu6pI3", "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"]
      );
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}