rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Explicit Admin Check (Flattened for speed)
    function isSystemAdmin() {
      return request.auth != null && (
        request.auth.token.get('email', '').lower() in [
          "mbustamante@hovidinc.com", 
          "admin@hovidinc.com", 
          "wbmaralit@hovidinc.com", 
          "kgpangan@hovidinc.com", 
          "pjramos@hovidinc.com"
        ] ||
        request.auth.uid in [
          "SgOR5cjCC6dZ0oABv4nXdntu6pI3", 
          "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"
        ]
      );
    }

    match /coverage/{userId}/{allPaths=**} {
      // Standard read for all authenticated users
      allow read: if request.auth != null;
      
      // Allow write if owner OR system administrator
      allow write: if request.auth != null && (request.auth.uid == userId || isSystemAdmin());
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}