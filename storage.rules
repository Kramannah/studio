rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Use .get() to avoid evaluation crashes if email is missing in token
      let email = request.auth.token.get('email', '').lower();
      let adminEmails = [
        "mbustamante@hovidinc.com", 
        "admin@hovidinc.com", 
        "wbmaralit@hovidinc.com"
      ];
      let adminUids = [
        "SgOR5cjCC6dZ0oABv4nXdntu6pI3", 
        "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"
      ];
      return email in adminEmails || request.auth.uid in adminUids;
    }

    // --- Path Rules ---

    match /coverage/{userId}/{allPaths=**} {
      // READ: Allow any authenticated user (DSM/Admin/PMR) to view the file
      allow read: if isSignedIn();
      
      // WRITE: Allow the folder owner OR a system administrator to write/migrate files
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
