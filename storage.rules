rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly authorize system admins via Token Data
    // This uses a flat structure to prevent evaluation errors during high-volume migrations.
    match /coverage/{userId}/{allPaths=**} {
      // Anyone logged in can read (for oversight/history)
      allow read: if isSignedIn();
      
      // Allow write if:
      // 1. The user is the owner of the folder
      // 2. The user is one of the verified system administrators
      allow write: if isSignedIn() && (
        request.auth.uid == userId || 
        request.auth.token.get('email', '').lower() == "mbustamante@hovidinc.com" ||
        request.auth.token.get('email', '').lower() == "admin@hovidinc.com" ||
        request.auth.token.get('email', '').lower() == "wbmaralit@hovidinc.com" ||
        request.auth.token.get('email', '').lower() == "kgpangan@hovidinc.com" ||
        request.auth.token.get('email', '').lower() == "pjramos@hovidinc.com" ||
        request.auth.uid == "SgOR5cjCC6dZ0oABv4nXdntu6pI3" ||
        request.auth.uid == "m2ZTNUi5v9ef82FxVRbwSmyGv9S2"
      );
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}