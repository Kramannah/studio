{
  "entities": {
    "Doctor": {
      "title": "Doctor",
      "description": "Represents a medical provider in the representative's master list.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "specialty": { "type": "string" },
        "clinic": { "type": "string" },
        "hcpCode": { "type": "string" },
        "frequency": { "enum": ["1x", "2x", "3x", "4x"] },
        "hacme": { "enum": ["YES", "NO"] },
        "province": { "type": "string" },
        "municipality": { "type": "string" }
      },
      "required": ["userId", "firstName", "lastName", "frequency"]
    },
    "CoverageEntry": {
      "title": "CoverageEntry",
      "description": "A log of a completed sales call or visit.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "coverageDate": { "type": "string", "format": "date-time" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "coverageType": { "enum": ["inbase", "outbase", "joint"] },
        "primaryProduct": { "type": "string" },
        "primaryProductQty": { "type": "number" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "signature": { "type": "string" }
      },
      "required": ["userId", "firstName", "lastName", "submittedAt"]
    },
    "NonCallDay": {
      "title": "NonCallDay",
      "description": "A record of a day where no calls were planned (leave, training, etc.).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "dayType": { "enum": ["wholeday", "halfday-am", "halfday-pm"] },
        "status": { "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["userId", "date", "reason", "status"]
    },
    "Plan": {
      "title": "Plan",
      "description": "A scheduled visit for a specific doctor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "doctorId": { "type": "string" },
        "plannedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "doctorId", "plannedDate"]
    },
    "PlanningPermissionRequest": {
      "title": "PlanningPermissionRequest",
      "description": "A request to unlock planning for a specific week.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "weekStartDate": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "status": { "enum": ["pending", "approved", "rejected"] },
        "requestedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "weekStartDate", "status"]
    },
    "TimeLog": {
      "title": "TimeLog",
      "description": "User attendance logs (Time In / Time Out).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timeIn": { "type": "string", "format": "date-time" },
        "timeOut": { "type": "string", "format": "date-time" },
        "locationType": { "enum": ["inbase", "outbase"] },
        "timeInPhoto": { "type": "string" },
        "timeOutPhoto": { "type": "string" }
      },
      "required": ["userId", "timeIn", "locationType"]
    },
    "Q4Allocation": {
      "title": "Q4Allocation",
      "description": "Inventory and marketing sample allocations.",
      "type": "object",
      "properties": {
        "prodGroupProdSubGroup": { "type": "string" },
        "displayMaterialName": { "type": "string" },
        "allocationQuantity": { "type": "number" },
        "quarter": { "enum": ["Q3", "Q4"] }
      },
      "required": ["displayMaterialName", "allocationQuantity"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/doctors/{id}": { "schema": { "$ref": "#/backend/entities/Doctor" }, "description": "User's master list of doctors." },
    "/coverageEntries/{id}": { "schema": { "$ref": "#/backend/entities/CoverageEntry" }, "description": "Submitted call reports." },
    "/nonCallDays/{id}": { "schema": { "$ref": "#/backend/entities/NonCallDay" }, "description": "Leave and non-activity requests." },
    "/plans/{id}": { "schema": { "$ref": "#/backend/entities/Plan" }, "description": "Scheduled visit plans." },
    "/planningRequests/{id}": { "schema": { "$ref": "#/backend/entities/PlanningPermissionRequest" }, "description": "Requests to unlock past planning weeks." },
    "/timeLogs/{id}": { "schema": { "$ref": "#/backend/entities/TimeLog" }, "description": "User attendance logs (Time In / Time Out)." },
    "/q4Allocation/{id}": { "schema": { "$ref": "#/backend/entities/Q4Allocation" }, "description": "Inventory and marketing sample allocations." }
  }
}